profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   For a binary/executable, it's recommend to shut it off or let users specify it.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different models, they may want to
#   keep Pipfile.lock out of version control.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either shared or ignored.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either shared or ignored.
#.pdm-python.path
#.pdm-build/

